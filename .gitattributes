# Git attributes for environment files
# Apply filters to prevent accidentally committing secrets

backend/.env filter=credentials diff=credentials
frontend/.env filter=credentials diff=credentials

# Mark these files as merge driver to avoid conflicts
backend/.env merge=ours
frontend/.env merge=ours

# Apply filter to any .env files at repo root or in subfolders
*.env filter=credentials diff=credentials
**/.env filter=credentials diff=credentials
