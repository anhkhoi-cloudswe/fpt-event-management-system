# Ignore environment and local secrets
.env                    # Root .env (Master - NEVER commit!)
backend/.env           # Backend local dev (legacy - for info only)

# Root level gitignore for FPT Event Management System

# Backend
backend/*.exe
backend/*.exe~
backend/bin/
backend/dist/
backend/bootstrap

# Frontend
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# IDE & Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS specific
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Build artifacts
*.zip
*.tar.gz

# Temporary files
*.tmp
*.temp

# Environment variables & Secrets
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.example.tfvars
example.tfvars.json

# Local .terraform directories
**/.terraform/*

# .terraform.lock files
.terraform.lock.hcl

# Secret values - NEVER commit these
*.pem
*.key
# Bastion SSH (Terraform local_file); public key may be committed if desired
infrastructure/fpt-bastion-ssh.pem
credentials.json
secrets.yaml
secrets.yml

# Crash logs
crash.log
crash.*.log

# Misc
.env
.env.*
*.log
*.bak
*.backup

# OS files
.DS_Store
Thumbs.db

