{
  "rewrites": [
    {
      "source": "/api/login",
      "destination": "https://fpt-event-management-system.onrender.com/api/v1/auth/login"
    },
    {
      "source": "/api/v1/auth/me",
      "destination": "https://fpt-event-management-system.onrender.com/api/v1/auth/me"
    },
    {
      "source": "/api/:path*",
      "destination": "https://fpt-event-management-system.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
