# ========================================
# Frontend Environment Variables
# ========================================
# Copy this file to .env.local for local development
# For Vercel deployment, set these variables in Project Settings > Environment Variables

# ========================================
# API Configuration
# ========================================
# API target URL - leave empty to use proxy (localhost:8080 in dev, gateway in prod)
# VITE_API_URL=http://localhost:8080

# ========================================
# Google reCAPTCHA v2
# ========================================
# Get your site key from: https://www.google.com/recaptcha/admin
# Required for: Login, Register, Reset Password pages
# Add domains in reCAPTCHA console:
#   - Development: localhost, 127.0.0.1
#   - Production: https://fpt-event.vercel.app
# IMPORTANT: Without this, reCAPTCHA widget will show "Invalid domain for site key" error
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ========================================
# Optional: System Time Override (for testing)
# ========================================
# Format: YYYY-MM-DD HH:mm:ss
# Used for testing time-dependent features (event start/end times, OTP expiry, etc.)
# Leave empty to use actual current time
# VITE_SYSTEM_TIME_OVERRIDE=

# ========================================
# Optional: E2E Testing
# ========================================
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# E2E_MOCK_EVENT_ID=1
# E2E_STUDENT_EMAIL=test@example.com
# E2E_STUDENT_PASSWORD=password
